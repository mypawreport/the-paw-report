{
  "name": "The Paw Report",
  "short_name": "Paw Report",
  "description": "Ground temp & walk safety for every dog. Check before every walk.",
  "start_url": "https://mypawreport.github.io/the-paw-report/",
  "scope": "https://mypawreport.github.io/the-paw-report/",
  "display": "standalone",
  "background_color": "#eaf0e8",
  "theme_color": "#0d9488",
  "orientation": "portrait",
  "categories": [
    "lifestyle",
    "health",
    "pets"
  ],
  "icons": [
    {
      "src": "https://mypawreport.github.io/the-paw-report/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "https://mypawreport.github.io/the-paw-report/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "lang": "en",
  "dir": "ltr",
  "screenshots": [
    {
      "src": "https://mypawreport.github.io/the-paw-report/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Paw Safety Dashboard"
    },
    {
      "src": "https://mypawreport.github.io/the-paw-report/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Area Safety & Crime Check"
    },
    {
      "src": "https://mypawreport.github.io/the-paw-report/screenshot3.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Walk History & Reminders"
    },
    {
      "src": "https://mypawreport.github.io/the-paw-report/screenshot_wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "The Paw Report - Full Feature Overview"
    }
  ],
  "shortcuts": [
    {
      "name": "Check Paw Safety",
      "short_name": "Paw Safety",
      "description": "Check current ground temperature safety",
      "url": "/?shortcut=safety",
      "icons": [
        {
          "src": "https://mypawreport.github.io/the-paw-report/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Hot Car Alert",
      "short_name": "Hot Car",
      "description": "Quick hot car check reminder",
      "url": "/?shortcut=hotcar",
      "icons": [
        {
          "src": "https://mypawreport.github.io/the-paw-report/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Walk History",
      "short_name": "History",
      "description": "View your recent walks",
      "url": "/?shortcut=history",
      "icons": [
        {
          "src": "https://mypawreport.github.io/the-paw-report/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "id": "com.mypawreport.thepawreport",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.mypawreport.thepawreport",
      "id": "com.mypawreport.thepawreport"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "browser"
  ],
  "scope_extensions": [
    {
      "origin": "https://mypawreport.github.io"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/csv": [
          ".csv"
        ],
        "application/json": [
          ".json"
        ]
      }
    }
  ],
  "launch_handler": {
    "client_mode": [
      "focus-existing",
      "auto"
    ]
  },
  "handle_links": "preferred",
  "share_target": {
    "action": "/?share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+pawreport",
      "url": "/?protocol=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/?action=new-note"
  },
  "widgets": [
    {
      "name": "Paw Safety Widget",
      "description": "Quick paw safety check",
      "tag": "paw-safety",
      "template": "paw-safety-template",
      "ms_ac_template": "widgets/paw-safety.json",
      "data": "widgets/paw-safety-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "https://mypawreport.github.io/the-paw-report/screenshot1.png",
          "sizes": "1080x1920",
          "label": "Paw Safety Widget"
        }
      ],
      "icons": [
        {
          "src": "https://mypawreport.github.io/the-paw-report/icon-192.png",
          "sizes": "192x192"
        }
      ],
      "auth": false,
      "update": 900
    }
  ]
}